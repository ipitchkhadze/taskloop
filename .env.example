# Скопируйте в `.env` и подставьте значения. Файл `.env` в git не коммитится.

# Рабочий каталог при `.\mvnw.cmd spring-boot:run` из этой папки — здесь же.



SERVER_PORT=8081



SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/taskdb

SPRING_DATASOURCE_USERNAME=task

SPRING_DATASOURCE_PASSWORD=task



LMSTUDIO_BASE_URL=http://localhost:1234/v1

LMSTUDIO_MODEL=

LMSTUDIO_API_KEY=

LMSTUDIO_CONNECT_TIMEOUT_SECONDS=10

LMSTUDIO_TIMEOUT_SECONDS=120

LMSTUDIO_MAX_TOKENS=2048

LMSTUDIO_MAX_TASK_TITLE_CHARS=200

LMSTUDIO_MAX_RESPONSE_CHARS=32000

LMSTUDIO_MAX_ADVICE_CONTEXT_CHARS=4000



ADVICE_RATE_LIMIT_ENABLED=true

ADVICE_RATE_LIMIT_REQUESTS=30

ADVICE_RATE_LIMIT_WINDOW_SECONDS=60

